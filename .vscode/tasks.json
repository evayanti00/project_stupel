{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Terminal sanity check",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Write-Output 'TASK_OK'"
			]
		},
		{
			"label": "Flutter run windows diagnostic",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"windows",
				"-v"
			],
			"isBackground": false
		},
		{
			"label": "Run EXE directly",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Start-Process -FilePath '.\\\\build\\\\windows\\\\x64\\\\runner\\\\Debug\\\\project_stupel.exe' ; Start-Sleep -Seconds 2 ; Get-Process project_stupel -ErrorAction SilentlyContinue | Select-Object Id,ProcessName,MainWindowTitle | Format-Table -AutoSize | Out-String"
			]
		},
		{
			"label": "Run flutter and stop on prompt",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"flutter run -d windows"
			],
			"isBackground": true
		},
